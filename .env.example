# Discord bot token (required)
DISCORD_TOKEN=

# Anthropic API key for post-correction (required)
ANTHROPIC_API_KEY=

# Discord channel ID for the bot to use (optional, can be passed per-call)
DISCORD_CHANNEL_ID=

# STT settings
WHISPER_MODEL=base          # tiny, base, small, medium, large-v3
WHISPER_DEVICE=cuda         # cuda or cpu
WHISPER_COMPUTE_TYPE=float16

# TTS settings
TTS_BACKEND=local           # "local" (Qwen3-TTS, requires GPU) or "elevenlabs" (cloud API)
TTS_VOICE=Ryan              # Voice profile name (preset or custom clone profile)
TTS_DEVICE=cuda
TTS_VOICES_DIR=voices       # Directory containing custom voice profiles

# ElevenLabs settings (only used when TTS_BACKEND=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=        # Voice ID from ElevenLabs dashboard
ELEVENLABS_MODEL_ID=eleven_flash_v2_5  # eleven_flash_v2_5 (fast) or eleven_v3 (quality)

# VAD settings
SILENCE_DURATION_MS=1500    # Silence duration to end utterance (ms)
VAD_THRESHOLD=0.5           # VAD probability threshold

# Correction
CORRECTION_MODEL=claude-haiku-4-5-20251001

# Speech Mode
SPEECH_MODE=pause           # "pause" or "stop_token"
STOP_WORD=over              # Stop word for stop_token mode
SPEECH_MAX_TIMEOUT_S=60.0   # Max listen timeout in seconds

# Server Transport
SERVER_HOST=127.0.0.1
SERVER_PORT=8765
SERVER_TRANSPORT=http       # "http" or "stdio"

# Spawn / CLI
DEFAULT_CLI=claude          # "claude" or "codex"
TERMINAL_EMULATOR=          # Override terminal detection (e.g. "kitty")

# Router (LLM intent classification for multi-session routing)
ROUTER_ENABLED=false
ROUTER_BACKEND=             # "openrouter", "codex_oauth", "openai_compatible"
ROUTER_MODEL=
ROUTER_API_KEY=
ROUTER_API_BASE_URL=
ROUTER_TIMEOUT_MS=500

# Voice Pool (per-session voice assignment)
VOICE_POOL=                 # Comma-separated: "Ryan,Aiden,Vivian"
SYSTEM_VOICE=               # Reserved for switchboard announcements

# Queue
MAX_QUEUE_DEPTH=20          # Max pending messages per session
