# Discord bot token (required)
DISCORD_TOKEN=

# Anthropic API key for post-correction (required)
ANTHROPIC_API_KEY=

# Discord channel ID for the bot to use (optional, can be passed per-call)
DISCORD_CHANNEL_ID=

# STT settings
WHISPER_MODEL=base          # tiny, base, small, medium, large-v3
WHISPER_DEVICE=cuda         # cuda or cpu
WHISPER_COMPUTE_TYPE=float16

# TTS settings
TTS_VOICE=Ryan              # Voice profile name (preset or custom clone profile)
TTS_DEVICE=cuda
TTS_VOICES_DIR=voices       # Directory containing custom voice profiles

# VAD settings
SILENCE_DURATION_MS=1500    # Silence duration to end utterance (ms)
VAD_THRESHOLD=0.5           # VAD probability threshold

# Correction
CORRECTION_MODEL=claude-haiku-4-5-20251001
